{
  "git": {
    "deploymentEnabled": {
      "dev": true,
      "main": false
    }
  },
  "buildCommand": "PUBLIC_URL=/ npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "env": {
    "PUBLIC_URL": "/"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
} 